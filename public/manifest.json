{
  "name": "AI Bug Reporter",
  "short_name": "AI Reporter",
  "description": "Progressive Web App to intelligently report Jira defects using Gemini.",
  "start_url": "/dashboard",
  "display": "standalone",
  "background_color": "#0A0C10",
  "theme_color": "#6366F1",
  "icons": [
    {
      "src": "/logo.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/logo.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "share_target": {
    "action": "/api/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "images",
          "accept": ["image/jpeg", "image/png", "image/webp", "image/gif"]
        }
      ]
    }
  }
}
